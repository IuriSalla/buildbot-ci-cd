# Copie para .env e ajuste (o ficheiro .env não deve ir para o Git).
#
# O master.cfg carrega automaticamente ../.env em relação à pasta master/
# (ou seja, este ficheiro na raiz do repositório buildbot/).

# Worker (mesmo utilizador em c['workers'] e nas builders)
BUILDBOT_WORKER_NAME=example-worker
BUILDBOT_WORKER_PASSWORD=change-me

# Web UI
BUILDBOT_ADMIN_USER=admin
BUILDBOT_ADMIN_PASSWORD=change-me

# URL pública do master (redirects, links na UI)
BUILDBOT_PUBLIC_URL=http://localhost:8010/

# Título na barra (opcional; default se vazio no código)
BUILDBOT_TITLE=Instant CI/CD Dev

# Link ao clicar no título (opcional; default = BUILDBOT_PUBLIC_URL)
BUILDBOT_TITLE_URL=http://localhost:8010/#/
